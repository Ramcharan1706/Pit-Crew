generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Intent {
  id             String   @id @default(uuid())
  userAddress    String
  condition      String
  targetValue    Float
  amountAlgo     Float
  recipient      String
  initialPrice   Float
  status         String   @default("active")
  triggeredAt    DateTime?
  triggerPrice   Float?
  executedAt     DateTime?
  executionTxId  String?
  expirationAt   DateTime?
  cancelledAt    DateTime?
  cancelReason   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("intents")
  @@index([userAddress])
  @@index([status])
  @@index([expirationAt])
}

model ProfileSettings {
  walletAddress            String   @id
  defaultExpiryMinutes     Int      @default(60)
  notificationsInApp       Boolean  @default(true)
  notificationsTrigger     Boolean  @default(true)
  notificationsExecution   Boolean  @default(true)
  notificationsPrice       Boolean  @default(false)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@map("profile_settings")
}
