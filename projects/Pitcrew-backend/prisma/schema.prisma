generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Intent {
  id             String   @id @default(cuid())
  userAddress    String   @db.VarChar(58)
  condition      String   @db.VarChar(50)
  targetValue    Float    @db.DoublePrecision
  amountAlgo     Float    @db.DoublePrecision
  recipient      String   @db.VarChar(58)
  initialPrice   Float    @db.DoublePrecision
  status         String   @default("active") @db.VarChar(50)
  triggeredAt    DateTime?
  triggerPrice   Float? @db.DoublePrecision
  executedAt     DateTime?
  executionTxId  String? @db.VarChar(255)
  expirationAt   DateTime?
  cancelledAt    DateTime?
  cancelReason   String? @db.VarChar(255)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("intents")
  @@index([userAddress])
  @@index([status])
  @@index([expirationAt])
  @@index([createdAt])
}

model ProfileSettings {
  walletAddress            String   @id @db.VarChar(58)
  defaultExpiryMinutes     Int      @default(60)
  notificationsInApp       Boolean  @default(true)
  notificationsTrigger     Boolean  @default(true)
  notificationsExecution   Boolean  @default(true)
  notificationsPrice       Boolean  @default(false)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@map("profile_settings")
}
